# ─────────────────────────────────────────────────────────────────────────────
# KIUVO CRM — Variables de entorno
# Copia este archivo al archivo correspondiente a tu ambiente y rellena los
# valores reales. NUNCA commites archivos .env con credenciales reales.
#
#   Desarrollo  →  .env.development
#   Staging     →  .env.staging
#   Producción  →  .env.production
#
# Vite carga los archivos en este orden (mayor prioridad primero):
#   .env.[mode].local  >  .env.local  >  .env.[mode]  >  .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# URL del proyecto Supabase de este ambiente.
# Encuéntrala en: supabase.com → tu proyecto → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clave anónima pública del proyecto (NO la service_role key).
# Encuéntrala en: supabase.com → tu proyecto → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key


# ── Identificador de ambiente ─────────────────────────────────────────────────
# Valores válidos: development | staging | production
# Usado para mostrar el badge de entorno en el panel admin y para lógica
# condicional (mock data, logging, etc.)
VITE_APP_ENV=development


# ── Nombre de la app ──────────────────────────────────────────────────────────
# Se muestra en el título del navegador y en la pantalla de carga.
VITE_APP_NAME=KIUVO CRM


# ── Feature flags ─────────────────────────────────────────────────────────────
# En desarrollo y staging se pueden activar datos mock cuando Supabase no
# responde o las tablas aún no existen.
# En producción debe ser false (o simplemente no definirse).
VITE_MOCK_FALLBACK=true

# Activa logs detallados de Supabase en la consola del navegador.
# Nunca debe estar en true en producción.
VITE_DEBUG_QUERIES=false


# ── Sentry (opcional — monitoreo de errores en staging/prod) ─────────────────
# Deja vacío para desactivar Sentry.
VITE_SENTRY_DSN=
